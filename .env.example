# @plurnk/plurnk-schemes-http — operator config reference.
#
# Family-namespaced per the metaproject env convention: every knob this package
# reads is PLURNK_SCHEMES_HTTP_*. The three numeric knobs are REQUIRED on the
# render path and read with no in-code default — an unset/invalid value fails
# hard at first use, naming the var (fail-hard contract; no silent fallbacks).
# A byte-fetch-only deployment (no HTML rendering) never reads them. The
# consuming service copies the vars it needs into its own .env; this file is
# the authoritative list of what the http scheme reads.

# ── Required (render path) ───────────────────────────────────────────────────
# Navigation/render timeout in ms (page.goto networkidle budget).
PLURNK_SCHEMES_HTTP_FETCH_TIMEOUT=30000
# Salvage threshold in body-text chars: a networkidle timeout whose DOM already
# holds at least this much innerText is the chatty-page case (long-poll, ad
# refresh) — the render is kept; below it the timeout propagates.
PLURNK_SCHEMES_HTTP_SALVAGE_MIN_BODY_CHARS=200
# Warm-chromium idle teardown in ms: the browser process closes after this long
# with no render activity, and relaunches on the next render.
PLURNK_SCHEMES_HTTP_IDLE_TIMEOUT=900000

# ── Optional (absence is a mode, not a default) ──────────────────────────────
# Remote CDP endpoint (shared chromium / Lightpanda / browserless). Unset →
# launch chromium locally via playwright.
# PLURNK_SCHEMES_HTTP_PLAYWRIGHT_WS=ws://localhost:9222
# "1" adds --no-sandbox to the local chromium launch (containers without
# user-namespace support). Unset → sandboxed.
# PLURNK_SCHEMES_HTTP_NO_SANDBOX=1
# Chromium JS heap cap in MB (--max-old-space-size). Unset → chromium default.
# PLURNK_SCHEMES_HTTP_CHROMIUM_HEAP_MB=2048
