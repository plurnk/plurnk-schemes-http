{
    "name": "@plurnk/plurnk-schemes-http",
    "version": "0.15.20",
    "description": "http(s):// URI scheme handler for the plurnk agent runtime — fetch + streaming response body.",
    "keywords": [
        "plurnk",
        "scheme",
        "uri",
        "http",
        "https"
    ],
    "homepage": "https://github.com/plurnk/plurnk-schemes-http#readme",
    "bugs": {
        "url": "https://github.com/plurnk/plurnk-schemes-http/issues"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/plurnk/plurnk-schemes-http.git"
    },
    "engines": {
        "node": ">=26"
    },
    "license": "MIT",
    "author": "@wikitopian",
    "type": "module",
    "publishConfig": {
        "access": "public"
    },
    "plurnk": {
        "kind": "scheme",
        "name": "http"
    },
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "default": "./dist/index.js"
        },
        "./package.json": "./package.json"
    },
    "files": [
        "dist/**/*",
        "docs/**/*",
        "README.md",
        "SPEC.md"
    ],
    "scripts": {
        "test:lint": "tsc --noEmit",
        "test:unit": "node --test src/**/*.test.ts",
        "test:integration": "node --test test/integration/**/*.test.ts",
        "test": "npm run test:lint && npm run test:unit",
        "build:dist": "tsc -p tsconfig.build.json",
        "build": "npm run build:dist",
        "prepare": "npm run build"
    },
    "dependencies": {
        "playwright": "1.61.1"
    },
    "peerDependencies": {
        "@plurnk/plurnk-schemes": "0.31.5"
    },
    "devDependencies": {
        "@plurnk/plurnk-schemes": "0.31.5",
        "@types/node": "26.0.1",
        "typescript": "6.0.3"
    }
}
